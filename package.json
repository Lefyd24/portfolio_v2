{
  "name": "portfolio-v3",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "python3 -m http.server 4173 --directory .",
    "build": "npm run build:feed && npm run build:css",
    "build:feed": "node ./scripts/build-feed.js",
    "build:css": "tailwind -i ./src/input.css -o ./public/output.css --minify",
    "watch:feed": "node ./scripts/watch-feed.js",
    "watch:css": "tailwind -i ./src/input.css -o ./public/output.css --watch",
    "deploy": "npm run build && npx wrangler pages deploy . --project-name=portfolio"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "react": "^19.2.4",
    "tailwindcss": "^3.4.10"
  },
  "dependencies": {
    "@fontsource/noto-sans": "^5.2.10",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/typography": "^0.5.19",
    "chokidar": "^5.0.0",
    "glob": "^13.0.6",
    "gray-matter": "^4.0.3",
    "marked": "^17.0.5",
    "satori": "^0.26.0"
  }
}
